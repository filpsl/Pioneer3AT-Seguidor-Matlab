                </material>
              </visual>
              <sensor name='hokuyo' type='gpu_lidar'>
                <topic>scan</topic>
                <update_rate>10</update_rate>
                <always_on>true</always_on>
                <visualize>true</visualize>
                <lidar>
                  <scan>
                    <horizontal>
                      <samples>640</samples>
                      <resolution>1</resolution>
                      <min_angle>-2.2688999999999999</min_angle>
                      <max_angle>2.2688999999999999</max_angle>
                    </horizontal>
                  </scan>
                  <range>
                    <min>0.080000000000000002</min>
                    <max>10</max>
                    <resolution>0.01</resolution>
                  </range>
                </lidar>
                <pose>0.14999999999999999 0 0.29999999999999999 0 0 0</pose>
                <gz_frame_id>lidar_link</gz_frame_id>
              </sensor>
            </link>
            <joint name='front_left_wheel_joint' type='revolute'>
              <pose relative_to='base_link'>0.13500000000000001 0.156 0.111 0 0 0</pose>
              <parent>base_link</parent>
              <child>front_left_wheel</child>
              <axis>
                <xyz>0 1 0</xyz>
                <limit>
                  <effort>100</effort>
                  <velocity>20</velocity>
                  <lower>-inf</lower>
                  <upper>inf</upper>
                </limit>
                <dynamics>
                  <damping>0.10000000000000001</damping>
                  <friction>0.10000000000000001</friction>
                  <spring_reference>0</spring_reference>
                  <spring_stiffness>0</spring_stiffness>
