    </inertial>
  </link>
  <joint name="base_top_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.003 0 0.274"/>
    <parent link="base_link"/>
    <child link="top_plate"/>
  </joint>
  <link name="front_left_wheel">
