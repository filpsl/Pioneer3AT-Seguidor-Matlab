<!--
  Pioneer 3-AT - descrição URDF/xacro para ROS 2 Humble + Gazebo Harmonic.

  Diferente do URDF antigo (que era SÓ visual e "não carregava no Gazebo"),
  este arquivo descreve o robô como um corpo físico:
    - <visual>    : a aparência (malhas STL reaproveitadas de meshes/)
    - <collision> : a forma usada pela física (primitivas simples: caixa/cilindro)
    - <inertial>  : massa + tensor de inércia (necessário p/ o robô se mover de verdade)

  Convenção de coordenadas:
    base_link tem origem no NÍVEL DO CHÃO, no centro do robô. O chassi é desenhado
    0.177 m acima, e os centros das rodas ficam a 0.111 m (raio 0.11 -> tocam o chão).

  Os blocos <gazebo> com os plugins (tração, juntas) e o sensor LiDAR são
  adicionados nas fases seguintes da migração.
-->
<robot name="pioneer3at">
  <!-- ============================================================= -->
  <!-- Materiais (cores para RViz e Gazebo)                          -->
  <!-- ============================================================= -->
  <material name="ChassisRed">
    <color rgba="0.851 0.0 0.0 1.0"/>
  </material>
  <material name="TopBlack">
    <color rgba="0.038 0.038 0.038 1.0"/>
  </material>
  <material name="AxleGrey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="HubcapYellow">
    <color rgba="1.0 0.811 0.151 1.0"/>
  </material>
  <material name="WheelBlack">
    <color rgba="0.117 0.117 0.117 1.0"/>
  </material>
  <material name="SonarYellow">
    <color rgba="0.715 0.583 0.210 1.0"/>
  </material>
  <!-- ============================================================= -->
  <!-- Chassi (base_link) - link raiz                                -->
  <!-- ============================================================= -->
  <link name="base_link">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.177"/>
      <geometry>
        <mesh filename="package://pioneer3at/meshes/chassis.stl"/>
      </geometry>
      <material name="ChassisRed"/>
    </visual>
    <!-- Colisão: caixa simples (0.501 x 0.400 x 0.190), do modelo antigo -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.177"/>
      <geometry>
        <box size="0.501 0.400 0.190"/>
      </geometry>
    </collision>
    <!-- Inércia do chassi reaproveitada do modelo antigo (massa 14 kg) -->
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.177"/>
      <mass value="14.0"/>
      <inertia ixx="0.3338" ixy="0.0" ixz="0.0" iyy="0.4783" iyz="0.0" izz="0.3338"/>
    </inertial>
  </link>
  <!-- ============================================================= -->
  <!-- Top plate (placa superior) - fixa ao chassi                  -->
