      <origin rpy="1.5708 0 0" xyz="0 0.041 0"/>
      <geometry>
        <cylinder length="0.075" radius="0.11"/>
      </geometry>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.041 0"/>
      <mass value="1.5"/>
      <!-- transverse = 1/12 m (3r^2 + l^2) ; axial(Y) = 1/2 m r^2 -->
      <inertia ixx="0.005240625" ixy="0.0" ixz="0.0" iyy="0.009075" iyz="0.0" izz="0.005240625"/>
    </inertial>
  </link>
  <!-- junta CONTÍNUA: agora a roda gira de verdade (eixo Y) -->
