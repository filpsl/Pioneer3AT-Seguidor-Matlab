      <mass value="1.5"/>
      <!-- transverse = 1/12 m (3r^2 + l^2) ; axial(Y) = 1/2 m r^2 -->
      <inertia ixx="0.005240625" ixy="0.0" ixz="0.0" iyy="0.009075" iyz="0.0" izz="0.005240625"/>
    </inertial>
  </link>
  <!-- junta CONTÍNUA: agora a roda gira de verdade (eixo Y) -->
  <joint name="rear_left_wheel_joint" type="continuous">
    <origin rpy="0 0 0" xyz="-0.135 0.156 0.111"/>
    <parent link="base_link"/>
    <child link="rear_left_wheel"/>
    <axis xyz="0 1 0"/>
    <limit effort="100.0" velocity="20.0"/>
    <dynamics damping="0.1" friction="0.1"/>
