      <geometry>
        <mesh filename="package://pioneer3at/meshes/front_sonar.stl"/>
      </geometry>
      <material name="SonarYellow"/>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
